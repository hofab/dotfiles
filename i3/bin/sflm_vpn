#!/bin/sh

CMD="$1"

OPENVPN3="/usr/bin/openvpn3"  # Or whatever `which openvpn3` says

case "${CMD}" in
    on|up)
        # openvpn3 session-start --config sflm
        "$OPENVPN3" session-manage --config sflm --resume
        ;;

    off|down)
        "$OPENVPN3" session-manage --config sflm --pause
        ;;

    *)
        nmcli con | egrep --color=NEVER '(NAME| vpn )'
        ;;
esac
