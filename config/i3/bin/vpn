#!/bin/bash

CMD="$1"
OVPN=$(which openvpn3)
CONFIG="sflm"

case "${CMD}" in
    on|up)
        # Check status and start if needed
        SESSION_OUTPUT=$("${OVPN}" sessions-list 2>/dev/null)

        if echo "${SESSION_OUTPUT}" | grep -q "No sessions available"; then
            "${OVPN}" session-start --config "${CONFIG}"
        else
            STATUS=$(echo "${SESSION_OUTPUT}" | grep "Status:" | sed 's/.*Status:[[:space:]]*//')
            if echo "${STATUS}" | grep -qi "paused"; then
                "${OVPN}" session-manage --config "${CONFIG}" --resume
            fi
        fi
        ;;

    off|down)
        "${OVPN}" session-manage --config "${CONFIG}" --pause
        ;;

    status)
        "${OVPN}" sessions-list
        ;;
esac
